# Shared password for editing the wiki. Leadership rotates as needed.
WIKI_PASSWORD=change-me-to-something-long

# Fine-grained GitHub PAT scoped to ONLY this repo with Contents: read+write.
# Rotate every 90 days.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where the wiki content is committed.
GITHUB_OWNER=mdplus-community
GITHUB_REPO=leadership-wiki
GITHUB_BRANCH=main

# JWT signing secret. Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-output-of-openssl-rand-hex-32

# Anthropic API key — powers the AI assistant in the editor.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxx

# Slack Bot Token — enables "Import from Slack thread" in the AI assistant.
# Requires a Slack app with channels:history and conversations:history scopes.
# Optional — the AI assistant works without this; Slack import just won't work.
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxxxxxxxx
